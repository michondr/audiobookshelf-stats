# Audiobookshelf connection (required)
ABS_URL=http://audiobookshelf
ABS_TOKEN=your-api-token-here

# Public (browser-facing) ABS URL, used for "open in ABS" links in the modal.
# Leave blank to hide the modal.
ABS_PUBLIC_URL=https://abs.example.com

# Local calendar timezone for day bucketing (IANA name)
TZ=Europe/Prague

# Optional overrides (defaults shown)
PORT=8080
DATA_DIR=/data

# Host user the container runs as, so the bind-mounted ./data stays writable
# and owned by you. Set to your `id -u` / `id -g`.
PUID=1000
PGID=1000
